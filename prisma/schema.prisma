// Prisma schema — WhatsSMS Shopify app

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

/// Per-shop app settings; WhatsSMS secret stored encrypted (AES-256-GCM).
model ShopSettings {
  shop     String @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encryptedWhatssmsSecret String?
  whatssmsApiBaseUrl      String?

  defaultSmsMode     String @default("devices")
  defaultSmsDeviceId String?
  defaultWaAccountId String?

  /// When true, WhatsSMS `shortener=1` is sent for SMS API calls.
  urlShortenerSms       Boolean @default(false)
  /// When true, WhatsSMS `shortener=1` is sent for WhatsApp API calls.
  urlShortenerWhatsapp Boolean @default(false)

  codEnabled        Boolean @default(true)
  codSendSms        Boolean @default(true)
  codSendWhatsapp   Boolean @default(false)
  codSmsTemplate    String  @default("Hi {{customer_first_name}},\nPlease click the link below to confirm your order:\n{{order_name}}\n{{line_items}}\n{{order_total}}\n\n{{confirm_url_sms}}\n\nIf you have any questions, feel free to contact us.\n\nRegards,\n{{shop_name}}")
  codWaTemplate     String  @default("Hi {{customer_first_name}},\nPlease click the link below to confirm your order:\n{{order_name}}\n{{line_items}}\n{{order_total}}\n\n{{confirm_url_wa}}\n\nIf you have any questions, feel free to contact us.\n\nRegards,\n{{shop_name}}")
  codLinkTtlHours   Int     @default(72)
  /// Comma-separated substrings for extra COD gateway detection (optional).
  codGatewayHints   String?

  marketingRequiresSmsConsent Boolean @default(true)
}

/// At most one "Order confirmed" customer notification per order (see `app/order_confirmed` automation; dedupes repeated `orders/updated` deliveries).
model OrderConfirmationNotification {
  id             String   @id @default(cuid())
  shop           String
  orderNumericId String
  createdAt      DateTime @default(now())

  @@unique([shop, orderNumericId])
  @@index([shop])
}

/// Configurable automation rules (parity with plugin philosophy).
model Automation {
  id        String   @id @default(cuid())
  shop      String
  key       String
  enabled   Boolean  @default(false)
  sendSms   Boolean  @default(false)
  sendWa    Boolean  @default(false)
  template  String   @default("")
  smsMode   String?
  smsDevice String?
  waAccount String?

  /// Minutes after the last `checkouts/update` before sending abandoned-cart recovery (only used when `key` is `checkouts/update`).
  abandonedCheckoutDelayMinutes Int @default(15)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, key])
}

/// Idempotent webhook processing (Shopify may retry).
model WebhookReceipt {
  id               String   @id @default(cuid())
  shop             String
  topic            String
  webhookId        String   @unique
  payloadHash      String?
  processedAt      DateTime @default(now())
}

/// COD confirmation tokens for public links (opaque + expiry).
model CodToken {
  id             String    @id @default(cuid())
  shop           String
  orderGid       String
  orderNumericId String
  publicToken    String    @unique
  expiresAt      DateTime
  resolvedAction String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  decisionIp        String?
  decisionUserAgent String?
  decisionLanguage  String?
  decisionReferer   String?

  @@index([shop, orderGid])
}

/// Lightweight job queue (process with worker/cron in production).
model AsyncJob {
  id        String   @id @default(cuid())
  shop      String
  type      String
  payload   String
  status    String   @default("pending")
  attempts  Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  runAfter  DateTime @default(now())

  @@index([status, runAfter])
}

/// Minimal customer PII for GDPR redaction mapping (optional rows).
model StoredCustomerRef {
  id          String @id @default(cuid())
  shop        String
  customerGid String
  createdAt   DateTime @default(now())

  @@unique([shop, customerGid])
}
