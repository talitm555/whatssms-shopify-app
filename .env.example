# Copy to `.env` for local development.
#
# Dev workflow (this repo): Cloudflare Tunnel → https://shopify.talitmahmood.com → Mac `127.0.0.1:3150`.
# Production: deploy app at https://ecom.whatssms.io (`shopify.app.toml` application_url).
# Open the embedded app in the browser only via the public HTTPS URL — not via localhost.
#
# PostgreSQL only. Local Mac example (create DB/user first):
#   DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/shopify_whatssms?schema=public"
# Docker app on Linux reaching Postgres published on host (e.g. n8n compose):
#   DATABASE_URL="postgresql://USER:PASSWORD@host.docker.internal:5432/shopify_whatssms?schema=public"
# Docker app on Linux reaching Postgres directly via Docker network:
#   DATABASE_URL="postgresql://USER:PASSWORD@automationslagashbiz-postgres-1:5432/shopify_whatssms?schema=public"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/shopify_whatssms?schema=public"

# Shared Docker Network Name for container connectivity
DB_NETWORK_NAME=automationslagashbiz_default

# Vite + `shopify app dev --localhost-port` (tunnel forwards here)
PORT=3150

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_orders,write_orders,read_customers,read_checkouts,read_fulfillments

# Public origin (no `/app` suffix). Must match `application_url` host in Partner / TOML.
SHOPIFY_APP_URL=https://shopify.talitmahmood.com

# Optional comma-separated extra app hosts for Remix CSRF alignment behind tunnels/proxies
# (primary is SHOPIFY_APP_URL). Example: https://ecom.whatssms.io,shopify.talitmahmood.com

# 32+ char secret for AES-256-GCM encryption of WhatsSMS API secrets.
# Required in production. Local development can fall back to SHOPIFY_API_SECRET.
APP_ENCRYPTION_SECRET=

# Public listing URL used by non-embedded public landing pages.
SHOPIFY_APP_STORE_LISTING_URL=https://apps.shopify.com/whatssms-io

# WhatsSMS REST API host (see dashboard docs). Example: https://app.whatssms.io
# Merchants' API keys must allow "get shorteners" (Connection page validates via GET /api/get/shorteners only).
WHATSSMS_API_BASE_URL=https://app.whatssms.io
